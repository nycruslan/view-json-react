{
  "name": "view-json-react",
  "version": "2.1.1",
  "description": "A lightweight, performant React component for visualizing JSON data with collapsible nodes, dark mode, and copy functionality",
  "type": "module",
  "main": "./dist/view-json-react.cjs",
  "module": "./dist/view-json-react.esm.js",
  "types": "./dist/index.d.ts",
  "sideEffects": [
    "./dist/view-json-react.esm.js",
    "./dist/view-json-react.cjs"
  ],
  "author": "Ruslan Shulga",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nycruslan/view-json-react.git"
  },
  "homepage": "https://nycruslan.github.io/view-json-react/?path=/docs/components-jsonviewer--docs",
  "bugs": {
    "url": "https://github.com/nycruslan/view-json-react/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/view-json-react.esm.js",
      "require": "./dist/view-json-react.cjs",
      "default": "./dist/view-json-react.esm.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/*.js",
    "dist/*.cjs",
    "dist/*.d.ts",
    "dist/*.map",
    "README.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "CODE_OF_CONDUCT.md",
    "LICENSE"
  ],
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/nycruslan"
  },
  "scripts": {
    "build": "pnpm run clean && vite build && pnpm run size",
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "lint": "eslint . --ext .ts,.tsx --fix",
    "prepare": "pnpm run build",
    "size": "size-limit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@size-limit/file": "^12.0.1",
    "@storybook/addon-docs": "^10.3.2",
    "@storybook/react": "^10.3.3",
    "@storybook/react-vite": "^10.3.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint-plugin-react-hooks": "^7.0.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sass": "^1.88.0",
    "size-limit": "^12.0.1",
    "storybook": "^10.3.3",
    "typescript": "^5.9.3",
    "vite": "^8.0.3",
    "vite-plugin-css-injected-by-js": "^3.5.2",
    "vite-plugin-dts": "^4.3.0"
  },
  "license": "MIT",
  "keywords": [
    "json",
    "react",
    "json viewer",
    "json visualizer",
    "react component",
    "data visualization",
    "collapsible json",
    "expandable json",
    "json tree view",
    "json explorer",
    "json parser",
    "interactive json",
    "development tool",
    "web development",
    "frontend",
    "UI component",
    "code visualization",
    "json formatter",
    "react library"
  ],
  "size-limit": [
    {
      "path": "dist/view-json-react.cjs",
      "limit": "20 KB"
    },
    {
      "path": "dist/view-json-react.esm.js",
      "limit": "20 KB"
    }
  ]
}
